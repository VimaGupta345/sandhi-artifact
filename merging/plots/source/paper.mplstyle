# Default figure size - assuming a single figure placed in a column by itself.
figure.figsize : 7, 3

# Default font size
font.size : 14

figure.dpi : 600

# Remove legend frame
legend.frameon : False

# Always save as 'tight'
savefig.bbox : tight
savefig.pad_inches : 0.05

# Hatches
hatch.linewidth : 0.5

pdf.fonttype : 42
ps.fonttype : 42

